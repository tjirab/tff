{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "packages/tff-core": {
      "package-name": "tff-core",
      "release-type": "python",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    },
    "packages/tff-sqlmesh": {
      "package-name": "tff-sqlmesh",
      "release-type": "python",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    },
    "packages/tff-dbt": {
      "package-name": "tff-dbt",
      "release-type": "python",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "tff",
      "packages": [
        "packages/tff-core",
        "packages/tff-sqlmesh",
        "packages/tff-dbt"
      ]
    }
  ]
}
